  "feature_engineering": {
    "share_target": "share = combo_y / total_y",
    "lags": 12,
    "rolling_windows": [
      3,
      6
    ],
    "month_encoding": [
      "month_sin",
      "month_cos"
    ],
    "renormalization": "share_pred := share_pred_raw / sum_over_combos(share_pred_raw) each month",
